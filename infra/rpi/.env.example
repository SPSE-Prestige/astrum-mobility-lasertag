## ─────────────────────────────────────────────
##  Laser Tag — RPi Production Environment
##  Zkopíruj jako .env a změň hesla!
##  cp .env.example .env
## ─────────────────────────────────────────────

# ── PostgreSQL ──
POSTGRES_USER=lasertag
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=lasertag

DATABASE_URL=postgresql://lasertag:CHANGE_ME_STRONG_PASSWORD@postgres:5432/lasertag?schema=public

# ── Redis ──
REDIS_URL=redis://redis:6379

# ── Go Backend ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
SERVER_PORT=8080

# ── JWT — vygeneruj: openssl rand -base64 32 ──
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
JWT_EXPIRATION=24h

# ── Herní nastavení ──
GAME_DEFAULT_HP=100
GAME_RESPAWN_DELAY=5s
GAME_MAX_PLAYERS=20

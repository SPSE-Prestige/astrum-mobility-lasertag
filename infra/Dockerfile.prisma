FROM node:20-alpine

RUN apk add --no-cache postgresql-client

WORKDIR /app

COPY database/package.json database/tsconfig.json ./
RUN npm install

COPY database/schema.prisma ./schema.prisma
COPY database/migrations ./migrations
RUN npx prisma generate

COPY database/seed.ts ./seed.ts
COPY scripts/wait-for-postgres.sh /usr/local/bin/wait-for-postgres
RUN chmod +x /usr/local/bin/wait-for-postgres

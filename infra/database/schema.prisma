generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  player
}

enum GameStatus {
  waiting
  running
  ended
}

model User {
  id           String         @id @default(uuid())
  username     String         @unique
  email        String         @unique
  passwordHash String         @map("password_hash")
  role         Role           @default(player)
  createdAt    DateTime       @default(now()) @map("created_at")
  gamePlayers  GamePlayer[]
  adminSessions AdminSession[]

  @@map("users")
}

model Game {
  id              String       @id @default(uuid())
  name            String
  gameMode        String       @map("game_mode")
  durationSeconds Int          @map("duration_seconds")
  status          GameStatus   @default(waiting)
  createdAt       DateTime     @default(now()) @map("created_at")
  gamePlayers     GamePlayer[]
  gameEvents      GameEvent[]

  @@map("games")
}

model GamePlayer {
  id        String   @id @default(uuid())
  gameId    String   @map("game_id")
  userId    String?  @map("user_id")
  nickname  String
  deviceId  String   @map("device_id")
  teamId    String?  @map("team_id")
  hp        Int      @default(100)
  lives     Int      @default(3)
  createdAt DateTime @default(now()) @map("created_at")

  game Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  shooterEvents GameEvent[] @relation("ShooterEvents")
  targetEvents  GameEvent[] @relation("TargetEvents")

  @@map("game_players")
}

model Team {
  id          String       @id @default(uuid())
  name        String
  color       String
  gamePlayers GamePlayer[]

  @@map("teams")
}

model Weapon {
  id         String      @id @default(uuid())
  name       String      @unique
  damage     Int
  fireRate   Int         @map("fire_rate")
  ammo       Int
  reloadTime Int         @map("reload_time")
  gameEvents GameEvent[]

  @@map("weapons")
}

model GameEvent {
  id        String   @id @default(uuid())
  gameId    String   @map("game_id")
  shooterId String   @map("shooter_id")
  targetId  String   @map("target_id")
  weaponId  String   @map("weapon_id")
  damage    Int
  type      String
  createdAt DateTime @default(now()) @map("created_at")

  game     Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  shooter  GamePlayer @relation("ShooterEvents", fields: [shooterId], references: [id], onDelete: Cascade)
  target   GamePlayer @relation("TargetEvents", fields: [targetId], references: [id], onDelete: Cascade)
  weapon   Weapon     @relation(fields: [weaponId], references: [id], onDelete: Cascade)

  @@map("game_events")
}

model AdminSession {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_sessions")
}
